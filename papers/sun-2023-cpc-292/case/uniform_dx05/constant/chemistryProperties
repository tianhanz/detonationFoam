FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
chemistryType
{
    solver          ode;
    method          standard;
}

chemistry       on;

initialChemicalTimeStep 1e-7;

odeCoeffs
{
    solver          Rosenbrock34;
    absTol          1e-10;
    relTol          1e-6;
}

#include "$FOAM_CASE/constant/foam/reactions.foam"

