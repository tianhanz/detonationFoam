FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Grid convergence: uniform_dx20
// Domain: 0.05 m, 2500 cells, dx = 20 um
// Uniform mesh

convertToMeters 1;

vertices
(
    (0.0    0.0    -0.001)
    (0.05  0.0    -0.001)
    (0.05  0.005  -0.001)
    (0.0    0.005  -0.001)
    (0.0    0.0     0.001)
    (0.05  0.0     0.001)
    (0.05  0.005   0.001)
    (0.0    0.005   0.001)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (2500 1 1) simpleGrading (1 1 1)
);

edges ();

boundary
(
    inlet
    {
        type wall;
        faces ( (0 4 7 3) );
    }
    outlet
    {
        type wall;
        faces ( (1 2 6 5) );
    }
    bottom
    {
        type wall;
        faces ( (0 1 5 4) );
    }
    top
    {
        type wall;
        faces ( (3 7 6 2) );
    }
    frontAndBack
    {
        type empty;
        faces ( (4 5 6 7) (0 3 2 1) );
    }
);

mergePatchPairs ();

