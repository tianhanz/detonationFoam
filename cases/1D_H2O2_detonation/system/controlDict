FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs
(
  "libchemistryModel_DLB.so"
);

application     detonationFoam_V2.0;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         50e-6;     // 50 us — sufficient for CJ detonation development

deltaT          1e-11;

writeControl    adjustableRunTime;

writeInterval   1e-6;     // write every 1 us

purgeWrite      0;

writeFormat     ascii;

writePrecision  12;

writeCompression off;

timeFormat      general;

timePrecision   12;

runTimeModifiable true;

adjustTimeStep  yes;

useAcousticCourant yes;

maxCo           0.1;
maxDeltaT       1e-6;
maxAcousticCo   0.1;

functions
{
}

