FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// 1D H2/O2 CJ detonation
// Domain: 0.2 m (20 cm), 40000 cells → dx = 5 um
// H2/O2 induction length ~ 0.1-0.5 mm at 1 atm → ~20-100 cells per induction

convertToMeters 1;

vertices
(
    (0.0  0.0 -0.005)
    (0.2  0.0 -0.005)
    (0.2  0.005 -0.005)
    (0.0  0.005 -0.005)
    (0.0  0.0  0.005)
    (0.2  0.0  0.005)
    (0.2  0.005  0.005)
    (0.0  0.005  0.005)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (40000 1 1) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    inlet
    {
        type wall;
        faces
        (
            (0 4 7 3)
        );
    }

    outlet
    {
        type wall;
        faces
        (
            (1 2 6 5)
        );
    }

    bottom
    {
        type wall;
        faces
        (
            (0 1 5 4)
        );
    }

    top
    {
        type wall;
        faces
        (
            (3 7 6 2)
        );
    }

    frontAndBack
    {
        type empty;
        faces
        (
            (4 5 6 7)
            (0 3 2 1)
        );
    }
);

mergePatchPairs
(
);

