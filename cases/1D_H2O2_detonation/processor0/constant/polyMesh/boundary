6
(
    inlet
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          1;
        startFace       4999;
    }
    outlet
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          0;
        startFace       5000;
    }
    bottom
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          5000;
        startFace       5000;
    }
    top
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          5000;
        startFace       10000;
    }
    frontAndBack
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          10000;
        startFace       15000;
    }
    procBoundary0to1
    {
        type            processor;
        inGroups        List<word> 1(processor);
        nFaces          1;
        startFace       25000;
        matchTolerance  0.0001;
        myProcNo        0;
        neighbProcNo    1;
    }
)

