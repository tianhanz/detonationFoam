FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// 2D AMR test case
// Domain: 0.05 m x 0.005 m
// Coarse base mesh: 250 x 25 = 6250 cells, dx = dy = 200 um
// AMR will refine 2 levels -> effective 50 um at the detonation front

convertToMeters 1;

vertices
(
    (0.0    0.0    -0.001)
    (0.05   0.0    -0.001)
    (0.05   0.005  -0.001)
    (0.0    0.005  -0.001)
    (0.0    0.0     0.001)
    (0.05   0.0     0.001)
    (0.05   0.005   0.001)
    (0.0    0.005   0.001)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (250 25 1) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    inlet
    {
        type wall;
        faces
        (
            (0 4 7 3)
        );
    }

    outlet
    {
        type wall;
        faces
        (
            (1 2 6 5)
        );
    }

    top
    {
        type cyclic;
        neighbourPatch bottom;
        faces
        (
            (3 7 6 2)
        );
    }

    bottom
    {
        type cyclic;
        neighbourPatch top;
        faces
        (
            (0 1 5 4)
        );
    }

    frontAndBack
    {
        type empty;
        faces
        (
            (4 5 6 7)
            (0 3 2 1)
        );
    }
);

mergePatchPairs
(
);

